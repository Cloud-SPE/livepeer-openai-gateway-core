{
  "name": "@cloudspe/livepeer-gateway-core",
  "version": "0.1.0",
  "description": "OSS engine: registry-driven node selection + payment-daemon orchestration + dispatchers + Fastify adapter for an OpenAI-compatible bridge over Livepeer WorkerNodes.",
  "license": "MIT",
  "homepage": "https://github.com/Cloud-SPE/livepeer-gateway-core",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Cloud-SPE/livepeer-gateway-core.git"
  },
  "bugs": {
    "url": "https://github.com/Cloud-SPE/livepeer-gateway-core/issues"
  },
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "exports": {
    ".": "./src/index.ts",
    "./*": "./src/*"
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "files": [
    "src",
    "migrations",
    "examples",
    "docs",
    "README.md",
    "AGENTS.md",
    "DESIGN.md",
    "LICENSE",
    "CHANGELOG.md",
    "CONTRIBUTING.md",
    "CODE_OF_CONDUCT.md",
    "GOVERNANCE.md",
    "SECURITY.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --coverage",
    "test:watch": "vitest",
    "lint": "eslint .",
    "fmt": "prettier --write .",
    "fmt:check": "prettier --check .",
    "proto:gen": "npm run proto:gen:payer && npm run proto:gen:registry",
    "proto:gen:payer": "rm -rf src/providers/payerDaemon/gen && mkdir -p src/providers/payerDaemon/gen && buf generate",
    "proto:gen:registry": "rm -rf src/providers/serviceRegistry/gen && mkdir -p src/providers/serviceRegistry/gen && buf generate --template buf.gen.serviceRegistry.yaml"
  },
  "peerDependencies": {
    "fastify": "^4.29.0",
    "@fastify/multipart": "^8.3.0",
    "@fastify/sensible": "^5.6.0",
    "@fastify/static": "^7.0.0"
  },
  "dependencies": {
    "@bufbuild/protobuf": "^2.12.0",
    "@grpc/grpc-js": "^1.14.3",
    "drizzle-orm": "^0.33.0",
    "eventsource-parser": "^3.0.8",
    "ioredis": "^5.10.1",
    "pg": "^8.20.0",
    "prom-client": "^15.1.3",
    "tiktoken": "^1.0.22",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@bufbuild/buf": "^1.68.4",
    "@fastify/multipart": "^8.3.1",
    "@fastify/sensible": "^5.6.0",
    "@fastify/static": "^7.0.4",
    "@testcontainers/postgresql": "^10.28.0",
    "@types/node": "^20.19.39",
    "@types/pg": "^8.20.0",
    "@vitest/coverage-v8": "^1.6.1",
    "eslint": "^9.39.4",
    "fastify": "^4.29.1",
    "fastify-raw-body": "^4.3.0",
    "prettier": "^3.8.3",
    "testcontainers": "^10.28.0",
    "ts-proto": "^2.11.6",
    "typescript": "^5.4.0",
    "typescript-eslint": "^8.59.0",
    "vitest": "^1.6.1"
  }
}
